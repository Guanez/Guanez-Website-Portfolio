"use client";

import { useEffect, useState } from "react";
import SimulationSequence from "@/components/SimulationSequence";
import LandingNav from "@/components/landing/LandingNav";
import ProjectGrid from "@/components/landing/ProjectGrid";

export default function Home() {
  const [showSim, setShowSim] = useState<boolean | null>(null);

  useEffect(() => {
    const seen = sessionStorage.getItem("intro_seen");
    setShowSim(!seen);
  }, []);

  const handleDone = () => {
    sessionStorage.setItem("intro_seen", "1");
    setShowSim(false);
  };

  const replay = () => {
    sessionStorage.removeItem("intro_seen");
    setShowSim(true);
  };

  return (
    <main className="relative h-dvh w-dvw bg-black overflow-hidden">
      <LandingNav />
      <ProjectGrid />

      {showSim && <SimulationSequence onDone={handleDone} />}

      <button
        onClick={replay}
        className="fixed bottom-5 right-5 z-40 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-xs text-white/70 backdrop-blur transition hover:bg-white/10 hover:text-white"
        aria-label="Replay intro animation"
      >
        ↻ Replay intro
      </button>
    </main>
  );
}
